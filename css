.container {
    width: 80%;
    margin: 0 auto;
    padding: 20px;
}

.header {
    background-color: #4CAF50;
    color: white;
    text-align: center;
    padding: 10px 0;
}

.attendance-list {
    border-collapse: collapse;
    width: 100%;
}

.attendance-list th, .attendance-list td {
    border: 1px solid #dddddd;
    text-align: left;
    padding: 8px;
}

.attendance-list th {
    background-color: #f2f2f2;
}

.button {
    background-color: #4CAF50;
    color: white;
    padding: 10px 15px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

.button:hover {
    background-color: #45a049;
}
